{
  "name": "airframe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build && node scripts/copy-public-assets.cjs",
    "start": "vite preview --host 0.0.0.0 --port 3000",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "npm run lint && npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "screenshot:constellation": "node scripts/constellation-screenshot.cjs"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "firebase": "^12.12.0",
    "lucide-react": "^0.561.0",
    "motion": "^12.38.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "tailwindcss": "^4.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@firebase/eslint-plugin-security-rules": "^0.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "chromedriver": "^148.0.0",
    "galenframework": "^2.4.4-build43",
    "jsdom": "^29.1.0",
    "playwright": "^1.59.1",
    "typescript": "~5.8.2",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  }
}
