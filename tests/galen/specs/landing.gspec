@objects
  landing css [data-galen-page="landing"]
  nav css [data-galen-page="landing"] nav
  heading css [data-galen-page="landing"] h1
  cta xpath //div[@data-galen-page='landing']//button[contains(., 'Start Training')]

= Landing Layout =
  landing:
    visible
    width 100 % of screen/width
    inside screen 0px top left right

  nav:
    visible
    inside viewport 0px top left right
    height 56 to 96px

  heading:
    visible
    below nav 40 to 180px
    inside screen 16 to 180px left right

  cta:
    visible
    below heading 20 to 80px
    inside screen 16 to 260px left right

@on desktop
  heading:
    width 40 to 80 % of screen/width

@on tablet
  heading:
    width 60 to 95 % of screen/width

@on mobile
  nav:
    height 56 to 88px

  heading:
    width 80 to 100 % of screen/width
