@objects
  shell css [data-galen-app-shell]
  main css [data-galen-main]
  page css [data-galen-page]
  sidebar css [data-galen-sidebar]
  mobileTop css [data-galen-mobile-top]
  mobileNav css [data-galen-mobile-nav]
  feedback css button[aria-label="Submit Feedback"]

= App Shell =
  shell:
    visible
    width 100 % of viewport/width
    height 100 % of viewport/height
    inside viewport 0px top left right bottom

  main:
    visible
    inside viewport 0px top bottom right

  page:
    visible
    inside main 0 to 96px left right

@on desktop
  sidebar:
    visible
    inside viewport 0px top left bottom
    width 240 to 280px

  main:
    right-of sidebar 0 to 4px

  mobileTop:
    absent

  mobileNav:
    absent

  feedback:
    visible
    inside viewport 24 to 48px right bottom

@on tablet,mobile
  sidebar:
    absent

  mobileTop:
    visible
    inside viewport 0px top left right
    height 48 to 88px

  mobileNav:
    visible
    inside viewport 0px left right bottom
    height 56 to 120px

  main:
    inside viewport 0px top left right bottom

  page:
    below mobileTop 0 to 16px

  feedback:
    visible
    above mobileNav 8 to 80px
    inside viewport 16 to 48px right

@on mobile
  page:
    width 100 % of main/width

@on tablet
  page:
    width 100 % of main/width
